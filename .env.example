# INTERCEPT environment — copy to .env.local and fill in at the hackathon.
# Convex (run `npx convex dev` once to populate the deployment vars)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Exa — THE MOAT (real, clickable community threads). Get a key at exa.ai.
EXA_API_KEY=

# OpenAI — router + intent scoring + reply drafting (gpt-4o-mini).
OPENAI_API_KEY=

# Google — Veo 3.1 Fast (video) + Gemini 2.5 Flash (watcher). Needs BILLING enabled.
GOOGLE_API_KEY=

# Orange Slice — enrichment + signal (NOT the on-camera thread source). From organizers.
ORANGE_SLICE_API_KEY=

# Optional: AgentMail (approval-gate inbox / send), Fiber (verified contacts) — vision/v2.
AGENTMAIL_API_KEY=
FIBER_API_KEY=
