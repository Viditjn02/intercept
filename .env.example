# INTERCEPT environment — copy to .env.local and fill in at the hackathon.
# Convex (run `npx convex dev` once to populate the deployment vars)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Exa — THE MOAT (real, clickable community threads). Get a key at exa.ai.
EXA_API_KEY=

# OpenAI — router + intent scoring + reply drafting (gpt-4o-mini).
OPENAI_API_KEY=

# Google — Veo 3.1 Fast (video) + Gemini 2.5 Flash (watcher). Needs BILLING enabled.
GOOGLE_API_KEY=

# Orange Slice — enrichment + signal (NOT the on-camera thread source). From organizers.
ORANGE_SLICE_API_KEY=

# AgentMail — send the human-approved reply/email (the outreach beat).
AGENTMAIL_API_KEY=

# fal.ai — open-source video fallback (LTX-Video) when Veo billing/latency bites. Faster, cheaper, no billing gate.
FAL_KEY=

# PostHog — live product analytics on the swarm (events stream on camera).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Meta Ad Library — competitor ad intelligence (AI Ad Factories). Graph API access token.
META_ACCESS_TOKEN=

# Fiber AI — verified contact/email enrichment (secondary send-data path).
FIBER_API_KEY=

# Composio — Gmail send path (production alternative to AgentMail).
COMPOSIO_API_KEY=

# gbrain — local compounding-knowledge CLI. No key: called as a dependency off PATH; degrades if absent.
